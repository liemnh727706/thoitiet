# Cổng chạy backend
PORT=4000

# TTL cache (giây) - thời gian giữ dữ liệu trước khi gọi lại Open-Meteo
CACHE_TTL_SECONDS=600

# (Tùy chọn) Redis - để trống thì dùng in-memory cache
REDIS_URL=

# (Tùy chọn) Push FCM - để TRỐNG thì tắt push, server vẫn chạy bình thường.
# Bật: trỏ tới file service account JSON của Firebase + cài `npm install firebase-admin`.
FCM_SERVICE_ACCOUNT=
FCM_TOPIC=weather-warnings
